<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Agente IA — Eduardo Aizprua</title>
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500;700&family=Syne:wght@400;600;800&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0a0f0a;
    --surface: #0d1a0d;
    --surface2: #102010;
    --border: #1a3a1a;
    --accent: #2ecc71;
    --accent2: #34495e;
    --accent3: #e67e22;
    --text: #e8e8f0;
    --text-dim: #bdc3c7;
    --text-muted: #145a32;
    --user-bubble: #0d1f0d;
    --ai-bubble: #071407;
    --danger: #ef4444;
    --warning: #f59e0b;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'JetBrains Mono', monospace;
    height: 100vh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  /* Noise texture overlay */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.03'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 0;
    opacity: 0.4;
  }

  /* Header */
  header {
    position: relative;
    z-index: 10;
    padding: 16px 24px;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: rgba(10,10,15,0.95);
    backdrop-filter: blur(12px);
  }

  .header-left {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .logo-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 12px var(--accent);
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; box-shadow: 0 0 12px var(--accent); }
    50% { opacity: 0.6; box-shadow: 0 0 4px var(--accent); }
  }

  .header-title {
    font-family: 'Syne', sans-serif;
    font-size: 15px;
    font-weight: 800;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--text);
  }

  .header-title span {
    color: var(--accent);
  }

  .header-meta {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .status-badge {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 10px;
    font-weight: 500;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 4px 10px;
    border: 1px solid var(--border);
    border-radius: 3px;
    background: var(--surface);
  }

  .status-badge .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent3);
    box-shadow: 0 0 6px var(--accent3);
  }

  .config-btn {
    background: none;
    border: 1px solid var(--border);
    color: var(--text-dim);
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    padding: 4px 10px;
    border-radius: 3px;
    cursor: pointer;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    transition: all 0.2s;
  }

  .config-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  /* Config panel */
  .config-panel {
    position: fixed;
    top: 0;
    right: -360px;
    width: 360px;
    height: 100%;
    background: var(--surface);
    border-left: 1px solid var(--border);
    z-index: 100;
    transition: right 0.3s ease;
    padding: 24px;
    overflow-y: auto;
  }

  .config-panel.open { right: 0; }

  .config-panel h3 {
    font-family: 'Syne', sans-serif;
    font-size: 13px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent);
    margin-bottom: 20px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--border);
  }

  .config-close {
    position: absolute;
    top: 20px;
    right: 20px;
    background: none;
    border: none;
    color: var(--text-dim);
    font-size: 18px;
    cursor: pointer;
  }

  .config-field {
    margin-bottom: 16px;
  }

  .config-field label {
    display: block;
    font-size: 10px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-dim);
    margin-bottom: 6px;
  }

  .config-field input, .config-field textarea {
    width: 100%;
    background: var(--surface2);
    border: 1px solid var(--border);
    color: var(--text);
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    padding: 8px 10px;
    border-radius: 4px;
    outline: none;
    transition: border-color 0.2s;
  }

  .config-field input:focus, .config-field textarea:focus {
    border-color: var(--accent);
  }

  .config-field textarea { resize: vertical; min-height: 80px; }

  .save-btn {
    width: 100%;
    padding: 10px;
    background: var(--accent);
    color: var(--bg);
    border: none;
    font-family: 'Syne', sans-serif;
    font-size: 12px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border-radius: 4px;
    cursor: pointer;
    margin-top: 8px;
    transition: opacity 0.2s;
  }

  .save-btn:hover { opacity: 0.85; }

  /* Phase indicator */
  .phase-bar {
    position: relative;
    z-index: 10;
    display: flex;
    align-items: center;
    gap: 0;
    padding: 0 24px;
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    overflow-x: auto;
  }

  .phase-item {
    padding: 8px 14px;
    font-size: 9px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    white-space: nowrap;
    display: flex;
    align-items: center;
    gap: 6px;
    border-right: 1px solid var(--border);
  }

  .phase-item.active {
    color: var(--accent);
    background: rgba(0,229,255,0.04);
  }

  .phase-item.done { color: var(--accent3); }

  .phase-num {
    width: 16px;
    height: 16px;
    border-radius: 50%;
    border: 1px solid currentColor;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 8px;
    font-weight: 700;
  }

  .phase-item.active .phase-num {
    background: var(--accent);
    color: var(--bg);
    border-color: var(--accent);
  }

  /* Main chat area */
  .chat-container {
    flex: 1;
    overflow-y: auto;
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    position: relative;
    z-index: 1;
  }

  .chat-container::-webkit-scrollbar { width: 4px; }
  .chat-container::-webkit-scrollbar-track { background: transparent; }
  .chat-container::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

  /* Messages */
  .message {
    display: flex;
    gap: 12px;
    animation: fadeIn 0.3s ease;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .message.user { flex-direction: row-reverse; }

  .avatar {
    width: 32px;
    height: 32px;
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 10px;
    font-weight: 700;
    flex-shrink: 0;
    font-family: 'Syne', sans-serif;
    text-transform: uppercase;
  }

  .avatar.ai {
    background: rgba(0,229,255,0.1);
    border: 1px solid rgba(0,229,255,0.3);
    color: var(--accent);
  }

  .avatar.user {
    background: rgba(124,58,237,0.1);
    border: 1px solid rgba(124,58,237,0.3);
    color: var(--accent2);
  }

  .bubble {
    max-width: 70%;
    padding: 12px 16px;
    border-radius: 6px;
    font-size: 13px;
    line-height: 1.6;
    position: relative;
  }

  .message.ai .bubble {
    background: var(--ai-bubble);
    border: 1px solid rgba(0,229,255,0.15);
    color: var(--text);
  }

  .message.user .bubble {
    background: var(--user-bubble);
    border: 1px solid rgba(124,58,237,0.15);
    color: var(--text);
    text-align: right;
  }

  .bubble-meta {
    font-size: 9px;
    color: var(--text-muted);
    margin-top: 6px;
    display: flex;
    align-items: center;
    gap: 8px;
    font-weight: 400;
  }

  .message.user .bubble-meta { justify-content: flex-end; }

  .log-tag {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 8px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 2px 6px;
    border-radius: 2px;
    background: rgba(16,185,129,0.1);
    color: var(--accent3);
    border: 1px solid rgba(16,185,129,0.2);
  }

  /* Typing indicator */
  .typing {
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 12px 16px;
    background: var(--ai-bubble);
    border: 1px solid rgba(0,229,255,0.15);
    border-radius: 6px;
    width: fit-content;
  }

  .typing span {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    animation: typing 1.2s ease-in-out infinite;
  }

  .typing span:nth-child(2) { animation-delay: 0.2s; }
  .typing span:nth-child(3) { animation-delay: 0.4s; }

  @keyframes typing {
    0%, 100% { opacity: 0.3; transform: scale(0.8); }
    50% { opacity: 1; transform: scale(1.1); }
  }

  /* Feedback buttons */
  .feedback-row {
    display: flex;
    gap: 6px;
    margin-top: 8px;
  }

  .feedback-btn {
    background: none;
    border: 1px solid var(--border);
    color: var(--text-dim);
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    padding: 3px 8px;
    border-radius: 3px;
    cursor: pointer;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    transition: all 0.2s;
  }

  .feedback-btn:hover.good { border-color: var(--accent3); color: var(--accent3); }
  .feedback-btn:hover.bad { border-color: var(--danger); color: var(--danger); }
  .feedback-btn.active.good { background: rgba(16,185,129,0.1); border-color: var(--accent3); color: var(--accent3); }
  .feedback-btn.active.bad { background: rgba(239,68,68,0.1); border-color: var(--danger); color: var(--danger); }

  /* Log drawer */
  .log-drawer {
    position: fixed;
    bottom: -300px;
    left: 0;
    right: 0;
    height: 300px;
    background: var(--surface);
    border-top: 1px solid var(--border);
    z-index: 50;
    transition: bottom 0.3s ease;
    padding: 16px 24px;
  }

  .log-drawer.open { bottom: 80px; }

  .log-drawer h4 {
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent);
    margin-bottom: 12px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .log-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 10px;
    overflow-y: auto;
    display: block;
    max-height: 200px;
  }

  .log-table::-webkit-scrollbar { height: 3px; width: 3px; }
  .log-table::-webkit-scrollbar-thumb { background: var(--border); }

  .log-table thead th {
    text-align: left;
    padding: 6px 8px;
    color: var(--text-dim);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    border-bottom: 1px solid var(--border);
    white-space: nowrap;
  }

  .log-table tbody tr {
    border-bottom: 1px solid var(--text-muted);
    opacity: 0.8;
  }

  .log-table tbody tr:hover { opacity: 1; background: rgba(255,255,255,0.02); }

  .log-table td {
    padding: 6px 8px;
    max-width: 200px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    color: var(--text);
  }

  .estado-ok { color: var(--accent3); }
  .estado-error { color: var(--danger); }
  .estado-pending { color: var(--warning); }

  /* Bottom bar */
  .input-area {
    position: relative;
    z-index: 10;
    padding: 16px 24px;
    border-top: 1px solid var(--border);
    background: rgba(10,10,15,0.95);
    backdrop-filter: blur(12px);
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .input-row {
    display: flex;
    gap: 8px;
    align-items: flex-end;
  }

  .input-wrapper {
    flex: 1;
    position: relative;
  }

  textarea.chat-input {
    width: 100%;
    background: var(--surface2);
    border: 1px solid var(--border);
    color: var(--text);
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    padding: 12px 16px;
    border-radius: 6px;
    outline: none;
    resize: none;
    min-height: 48px;
    max-height: 160px;
    line-height: 1.5;
    transition: border-color 0.2s;
    overflow-y: auto;
  }

  textarea.chat-input:focus { border-color: rgba(0,229,255,0.4); }
  textarea.chat-input::placeholder { color: var(--text-muted); }

  .send-btn {
    width: 48px;
    height: 48px;
    background: var(--accent);
    border: none;
    border-radius: 6px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: all 0.2s;
    color: var(--bg);
  }

  .send-btn:hover { transform: scale(1.05); box-shadow: 0 0 16px rgba(0,229,255,0.4); }
  .send-btn:active { transform: scale(0.97); }
  .send-btn:disabled { opacity: 0.4; cursor: not-allowed; transform: none; }

  .send-btn svg { width: 18px; height: 18px; }

  .bottom-controls {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .bottom-left {
    display: flex;
    gap: 8px;
    align-items: center;
  }

  .ctrl-btn {
    background: none;
    border: 1px solid var(--border);
    color: var(--text-dim);
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    padding: 4px 10px;
    border-radius: 3px;
    cursor: pointer;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    transition: all 0.2s;
    display: flex;
    align-items: center;
    gap: 5px;
  }

  .ctrl-btn:hover { border-color: var(--accent); color: var(--accent); }
  .ctrl-btn.active { border-color: var(--accent); color: var(--accent); background: rgba(0,229,255,0.05); }

  .char-count {
    font-size: 9px;
    color: var(--text-muted);
    letter-spacing: 0.04em;
  }

  /* Sheet status */
  .sheet-status {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 9px;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .sheet-status .dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
  }

  .sheet-status.connected .dot { background: var(--accent3); box-shadow: 0 0 4px var(--accent3); }
  .sheet-status.disconnected .dot { background: var(--warning); }
  .sheet-status.error .dot { background: var(--danger); }

  /* Welcome screen */
  .welcome {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    flex: 1;
    gap: 20px;
    padding: 40px;
    text-align: center;
  }

  .welcome-icon {
    width: 64px;
    height: 64px;
    border: 1px solid rgba(0,229,255,0.3);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0,229,255,0.05);
  }

  .welcome h2 {
    font-family: 'Syne', sans-serif;
    font-size: 22px;
    font-weight: 800;
    color: var(--text);
  }

  .welcome h2 span { color: var(--accent); }

  .welcome p {
    font-size: 12px;
    color: var(--text-dim);
    max-width: 380px;
    line-height: 1.7;
  }

  .suggestion-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
    margin-top: 8px;
    max-width: 480px;
    width: 100%;
  }

  .suggestion {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 12px 14px;
    cursor: pointer;
    text-align: left;
    transition: all 0.2s;
    font-family: 'JetBrains Mono', monospace;
  }

  .suggestion:hover {
    border-color: rgba(0,229,255,0.3);
    background: rgba(0,229,255,0.03);
  }

  .suggestion .label {
    font-size: 9px;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 4px;
  }

  .suggestion .text {
    font-size: 11px;
    color: var(--text);
    line-height: 1.4;
  }

  /* Error message */
  .error-msg {
    background: rgba(239,68,68,0.08);
    border: 1px solid rgba(239,68,68,0.25);
    border-radius: 6px;
    padding: 10px 14px;
    font-size: 11px;
    color: var(--danger);
    margin-top: 8px;
  }

  /* Overlay */
  .overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.5);
    z-index: 90;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s;
  }

  .overlay.active { opacity: 1; pointer-events: all; }

  /* Voice buttons */
  .mic-btn {
    width: 48px;
    height: 48px;
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 6px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: all 0.2s;
    color: var(--text-dim);
  }
  .mic-btn:hover { border-color: var(--accent); color: var(--accent); }
  .mic-btn.recording {
    border-color: var(--danger);
    color: var(--danger);
    background: rgba(239,68,68,0.1);
    animation: micPulse 1s ease-in-out infinite;
  }
  @keyframes micPulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(239,68,68,0.4); }
    50% { box-shadow: 0 0 0 8px rgba(239,68,68,0); }
  }
  .mic-btn svg { width: 18px; height: 18px; }
  .tts-btn {
    background: none;
    border: 1px solid var(--border);
    color: var(--text-dim);
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    padding: 3px 8px;
    border-radius: 3px;
    cursor: pointer;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    transition: all 0.2s;
  }
  .tts-btn:hover { border-color: var(--accent2); color: var(--accent2); }
  .tts-btn.speaking { border-color: var(--accent2); color: var(--accent2); background: rgba(124,58,237,0.1); }
</style>
</head>
<body>

<!-- Header -->
<header>
  <div class="header-left">
    <div class="logo-dot"></div>
    <span class="header-title">Agente<span>_IA</span></span>
  </div>
  <div class="header-meta">
    <div class="status-badge">
      <div class="dot"></div>
      <span>Groq LLaMA 3.1 · 🔍 Tavily</span>
    </div>
    <button class="config-btn" onclick="toggleConfig()">⚙ Config</button>
  </div>
</header>

<!-- Phase bar -->
<div class="phase-bar">
  <div class="phase-item done">
    <div class="phase-num">1</div>
    Base + Gemini
  </div>
  <div class="phase-item done">
    <div class="phase-num">2</div>
    Memoria Sheets
  </div>
  <div class="phase-item done">
    <div class="phase-num">3</div>
    Voz
  </div>
  <div class="phase-item active">
    <div class="phase-num">4</div>
    Aprendizaje
  </div>
</div>

<!-- Config panel -->
<div class="overlay" id="overlay" onclick="toggleConfig()"></div>
<div class="config-panel" id="configPanel">
  <button class="config-close" onclick="toggleConfig()">✕</button>
  <h3>⚙ Configuración</h3>

  <div class="config-field">
    <label>Gemini API Key *</label>
    <input type="password" id="cfg-gemini-key" placeholder="AIza..." />
  </div>
  <div class="config-field">
    <label>Google Sheets ID</label>
    <input type="text" id="cfg-sheet-id" value="1JbcsekjdeU1o91ByS9OaT0xdiBsH1A-c-C6tNmO4Rk8" />
  </div>
  <div class="config-field">
    <label>Sheets API Key *</label>
    <input type="password" id="cfg-sheets-key" placeholder="AIza..." />
  </div>
  <div class="config-field">
    <label>System Prompt (personalidad del agente)</label>
    <textarea id="cfg-system-prompt">Eres un agente IA inteligente y útil. Responde en español. Eres preciso, conciso y amigable. Cuando no sepas algo, dilo claramente.</textarea>
  </div>
  <div class="config-field">
    <label>Nombre del agente</label>
    <input type="text" id="cfg-agent-name" value="Agente IA" />
  </div>
  <button class="save-btn" onclick="saveConfig()">Guardar configuración</button>

  <div style="margin-top:20px; padding: 12px; background: var(--surface2); border-radius:4px; border: 1px solid var(--border);">
    <div style="font-size:9px; color: var(--text-dim); text-transform:uppercase; letter-spacing:0.08em; margin-bottom:8px;">Notas de desarrollo</div>
    <div style="font-size:10px; color: var(--text-muted); line-height:1.6;">
      • Fase 2: Sheets guardará logs [Comando, Respuesta, Feedback, Estado]<br>
      • Fase 3: Web Speech API para voz<br>
      • Fase 4: Feedback loop → auto-aprendizaje
    </div>
  </div>
</div>

<!-- Chat container -->
<div class="chat-container" id="chatContainer">
  <!-- Welcome screen -->
  <div class="welcome" id="welcomeScreen">
    <div class="welcome-icon">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="color: var(--accent)">
        <path d="M12 2a2 2 0 0 1 2 2c0 .74-.4 1.39-1 1.73V7h1a7 7 0 0 1 7 7h1a1 1 0 0 1 1 1v3a1 1 0 0 1-1 1h-1v1a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-1H2a1 1 0 0 1-1-1v-3a1 1 0 0 1 1-1h1a7 7 0 0 1 7-7h1V5.73c-.6-.34-1-.99-1-1.73a2 2 0 0 1 2-2z"/>
      </svg>
    </div>
    <div>
      <h2>Hola, <span>Eduardo</span></h2>
      <p style="margin-top:6px">Agente IA — Fase 1 · Configurá tu API Key de Gemini en ⚙ Config para comenzar.</p>
    </div>
    <div class="suggestion-grid">
      <div class="suggestion" onclick="useSuggestion('¿Cuál es el estado del proyecto TechZone?')">
        <div class="label">📦 TechZone</div>
        <div class="text">Estado del proyecto</div>
      </div>
      <div class="suggestion" onclick="useSuggestion('¿Cómo funciona el feedback loop en IA?')">
        <div class="label">🧠 IA</div>
        <div class="text">Feedback loop</div>
      </div>
      <div class="suggestion" onclick="useSuggestion('Explica la arquitectura del agente IA que estamos construyendo')">
        <div class="label">🏗 Arquitectura</div>
        <div class="text">Este proyecto</div>
      </div>
      <div class="suggestion" onclick="useSuggestion('¿Cómo soluciono el problema de zona horaria en Vercel?')">
        <div class="label">🕐 Fix</div>
        <div class="text">Zona horaria Vercel</div>
      </div>
    </div>
  </div>
</div>

<!-- Log drawer -->
<div class="log-drawer" id="logDrawer">
  <h4>
    <span>📋 Logs de sesión</span>
    <button onclick="clearLogs()" style="background:none;border:none;color:var(--danger);cursor:pointer;font-size:9px;font-family:'JetBrains Mono',monospace;text-transform:uppercase;letter-spacing:0.06em;">Limpiar</button>
  </h4>
  <table class="log-table">
    <thead>
      <tr>
        <th>#</th>
        <th>Comando</th>
        <th>Respuesta (preview)</th>
        <th>Feedback</th>
        <th>Estado</th>
        <th>Hora</th>
      </tr>
    </thead>
    <tbody id="logTableBody">
      <tr>
        <td colspan="6" style="color: var(--text-muted); text-align:center; padding: 16px;">Sin logs aún</td>
      </tr>
    </tbody>
  </table>
</div>

<!-- Input area -->
<div class="input-area">
  <div class="input-row">
    <div class="input-wrapper">
      <textarea
        class="chat-input"
        id="chatInput"
        placeholder="Escribe tu mensaje..."
        rows="1"
        onkeydown="handleKeyDown(event)"
        oninput="handleInput(this)"
      ></textarea>
    </div>
    <button class="send-btn" id="sendBtn" onclick="sendMessage()">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="22" y1="2" x2="11" y2="13"></line>
        <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
      </svg>
    </button>
    <button class="mic-btn" id="micBtn" onclick="toggleMic()" title="Hablar">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/>
        <path d="M19 10v2a7 7 0 0 1-14 0v-2"/>
        <line x1="12" y1="19" x2="12" y2="23"/>
        <line x1="8" y1="23" x2="16" y2="23"/>
      </svg>
    </button>
  </div>
  <div class="bottom-controls">
    <div class="bottom-left">
      <button class="ctrl-btn" id="logBtn" onclick="toggleLogs()">
        📋 Logs <span id="logCount">0</span>
      </button>
      <button class="ctrl-btn" onclick="clearChat()">
        🗑 Limpiar chat
      </button>
    </div>
    <div style="display:flex;align-items:center;gap:12px;">
      <div class="sheet-status connected" id="sheetStatus">
        <div class="dot"></div>
        <span>Sheets: activo</span>
      </div>
      <span class="char-count"><span id="charCount">0</span> chars</span>
    </div>
  </div>
</div>

<script>
// State
let messages = [];
let logs = [];
let sessionId = 'session_' + Date.now();
let config = {
  geminiKey: '',
  sheetId: '1JbcsekjdeU1o91ByS9OaT0xdiBsH1A-c-C6tNmO4Rk8',
  sheetsKey: '',
  systemPrompt: 'Eres un agente IA inteligente y útil. Responde en español. Eres preciso, conciso y amigable. Cuando no sepas algo, dilo claramente.',
  agentName: 'Agente IA'
};
let isLoading = false;
let logsVisible = false;

// Load config from localStorage
function loadConfig() {
  try {
    const saved = localStorage.getItem('agente-ia-config');
    if (saved) {
      config = { ...config, ...JSON.parse(saved) };
      document.getElementById('cfg-gemini-key').value = config.geminiKey || '';
      document.getElementById('cfg-sheet-id').value = config.sheetId || '';
      document.getElementById('cfg-sheets-key').value = config.sheetsKey || '';
      document.getElementById('cfg-system-prompt').value = config.systemPrompt || '';
      document.getElementById('cfg-agent-name').value = config.agentName || '';
    }
  } catch(e) {}
}

function saveConfig() {
  config.geminiKey = document.getElementById('cfg-gemini-key').value;
  config.sheetId = document.getElementById('cfg-sheet-id').value;
  config.sheetsKey = document.getElementById('cfg-sheets-key').value;
  config.systemPrompt = document.getElementById('cfg-system-prompt').value;
  config.agentName = document.getElementById('cfg-agent-name').value;

  localStorage.setItem('agente-ia-config', JSON.stringify(config));
  toggleConfig();
  showToast('✅ Configuración guardada');
}

// Toast
function showToast(msg) {
  const toast = document.createElement('div');
  toast.style.cssText = `
    position: fixed; bottom: 100px; left: 50%; transform: translateX(-50%);
    background: var(--surface2); border: 1px solid var(--border);
    color: var(--text); font-family: 'JetBrains Mono', monospace;
    font-size: 11px; padding: 8px 16px; border-radius: 4px; z-index: 200;
    animation: fadeIn 0.2s ease;
  `;
  toast.textContent = msg;
  document.body.appendChild(toast);
  setTimeout(() => toast.remove(), 2500);
}

// UI helpers
function toggleConfig() {
  const panel = document.getElementById('configPanel');
  const overlay = document.getElementById('overlay');
  panel.classList.toggle('open');
  overlay.classList.toggle('active');
}

function toggleLogs() {
  logsVisible = !logsVisible;
  const drawer = document.getElementById('logDrawer');
  const btn = document.getElementById('logBtn');
  drawer.classList.toggle('open', logsVisible);
  btn.classList.toggle('active', logsVisible);
}

function clearLogs() {
  logs = [];
  renderLogs();
  updateLogCount();
}

function clearChat() {
  messages = [];
  const container = document.getElementById('chatContainer');
  container.innerHTML = '';
  addWelcome();
}

function addWelcome() {
  const container = document.getElementById('chatContainer');
  container.innerHTML = `
    <div class="welcome" id="welcomeScreen">
      <div class="welcome-icon">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="color: var(--accent)">
          <path d="M12 2a2 2 0 0 1 2 2c0 .74-.4 1.39-1 1.73V7h1a7 7 0 0 1 7 7h1a1 1 0 0 1 1 1v3a1 1 0 0 1-1 1h-1v1a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-1H2a1 1 0 0 1-1-1v-3a1 1 0 0 1 1-1h1a7 7 0 0 1 7-7h1V5.73c-.6-.34-1-.99-1-1.73a2 2 0 0 1 2-2z"/>
        </svg>
      </div>
      <div>
        <h2>Hola, <span>Eduardo</span></h2>
        <p style="margin-top:6px">Chat reiniciado · Configurá tu API Key de Gemini en ⚙ Config para comenzar.</p>
      </div>
    </div>
  `;
}

// Auto-resize textarea
function handleInput(el) {
  el.style.height = 'auto';
  el.style.height = Math.min(el.scrollHeight, 160) + 'px';
  document.getElementById('charCount').textContent = el.value.length;
}

function handleKeyDown(e) {
  if (e.key === 'Enter' && !e.shiftKey) {
    e.preventDefault();
    sendMessage();
  }
}

function useSuggestion(text) {
  const input = document.getElementById('chatInput');
  input.value = text;
  handleInput(input);
  sendMessage();
}

// Time
function getTime() {
  return new Date().toLocaleTimeString('es-PA', { hour: '2-digit', minute: '2-digit', timeZone: 'America/Panama' });
}

// Render message
function addMessage(role, content, logIndex) {
  const welcome = document.getElementById('welcomeScreen');
  if (welcome) welcome.remove();

  const container = document.getElementById('chatContainer');
  const div = document.createElement('div');
  div.className = `message ${role}`;
  div.id = role === 'ai' ? `msg-${logIndex}` : '';

  const avatarLabel = role === 'ai' ? (config.agentName || 'AI').substring(0, 2).toUpperCase() : 'EA';

  div.innerHTML = `
    <div class="avatar ${role}">${avatarLabel}</div>
    <div class="bubble">
      ${escapeHtml(content).replace(/\n/g, '<br>')}
      <div class="bubble-meta">
        <span>${getTime()}</span>
        ${role === 'ai' ? `<span class="log-tag">✓ log #${logIndex + 1}</span>` : ''}
      </div>
      ${role === 'ai' ? `
        <div class="feedback-row">
          <button class="feedback-btn good" onclick="giveFeedback(${logIndex}, 'bueno', this)">👍 Bueno</button>
          <button class="feedback-btn bad" onclick="giveFeedback(${logIndex}, 'malo', this)">👎 Malo</button>
          <button class="tts-btn" id="tts-${logIndex}" onclick="speakText(this, ${logIndex})">🔊 Escuchar</button>
          <button class="tts-btn" onclick="promptRecordar(${logIndex})">💾 Recordar</button>
        </div>
      ` : ''}
    </div>
  `;

  container.appendChild(div);
  container.scrollTop = container.scrollHeight;
}

function escapeHtml(text) {
  return text.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

// Typing indicator
function showTyping() {
  const welcome = document.getElementById('welcomeScreen');
  if (welcome) welcome.remove();

  const container = document.getElementById('chatContainer');
  const div = document.createElement('div');
  div.className = 'message ai';
  div.id = 'typing-indicator';
  div.innerHTML = `
    <div class="avatar ai">${(config.agentName || 'AI').substring(0, 2).toUpperCase()}</div>
    <div class="typing"><span></span><span></span><span></span></div>
  `;
  container.appendChild(div);
  container.scrollTop = container.scrollHeight;
}

function hideTyping() {
  const el = document.getElementById('typing-indicator');
  if (el) el.remove();
}

// Logs
function addLog(command, response, feedback, estado) {
  logs.push({ command, response, feedback, estado, time: getTime(), idx: logs.length });
  renderLogs();
  updateLogCount();
}

function renderLogs() {
  const tbody = document.getElementById('logTableBody');
  if (logs.length === 0) {
    tbody.innerHTML = `<tr><td colspan="6" style="color: var(--text-muted); text-align:center; padding: 16px;">Sin logs aún</td></tr>`;
    return;
  }
  tbody.innerHTML = logs.slice().reverse().map((l, i) => `
    <tr>
      <td style="color:var(--text-dim)">${logs.length - i}</td>
      <td>${escapeHtml(l.command.substring(0, 40))}${l.command.length > 40 ? '…' : ''}</td>
      <td style="color:var(--text-dim)">${escapeHtml(l.response.substring(0, 50))}${l.response.length > 50 ? '…' : ''}</td>
      <td>${l.feedback === 'bueno' ? '👍' : l.feedback === 'malo' ? '👎' : '<span style="color:var(--text-muted)">—</span>'}</td>
      <td class="estado-${l.estado === 'ok' ? 'ok' : l.estado === 'error' ? 'error' : 'pending'}">${l.estado.toUpperCase()}</td>
      <td style="color:var(--text-dim)">${l.time}</td>
    </tr>
  `).join('');
}

function updateLogCount() {
  document.getElementById('logCount').textContent = logs.length;
}

// Guardar log en Google Sheets via API Route
async function saveLogToSheets(comando, respuesta, feedback, estado) {
  try {
    await fetch('/api/logs', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ comando, respuesta, feedback, estado })
    });
  } catch(e) {
    console.warn('No se pudo guardar en Sheets:', e.message);
  }
}

// Feedback
function giveFeedback(logIndex, value, btn) {
  if (logs[logIndex]) {
    logs[logIndex].feedback = value;
    renderLogs();
    const row = btn.closest('.feedback-row');
    row.querySelectorAll('.feedback-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    saveLogToSheets(logs[logIndex].command, logs[logIndex].response, value, logs[logIndex].estado);
    showToast(value === 'bueno' ? '👍 Guardado en Sheets' : '👎 Guardado en Sheets');
  }
}

// Main send function
async function sendMessage() {
  const input = document.getElementById('chatInput');
  const text = input.value.trim();
  if (!text || isLoading) return;

  if (!config.geminiKey) {
    showToast('⚠ Configura tu API Key de Gemini primero');
    toggleConfig();
    return;
  }

  const logIndex = logs.length;
  isLoading = true;
  document.getElementById('sendBtn').disabled = true;

  // Clear input
  input.value = '';
  input.style.height = 'auto';
  document.getElementById('charCount').textContent = '0';

  // Add user message
  addMessage('user', text);
  messages.push({ role: 'user', parts: [{ text }] });
  saveToHistory('user', text);

  // Show typing
  showTyping();

  // Add placeholder log
  addLog(text, '...', 'pendiente', 'pending');

  try {
    // Consultar memoria solo cada 5 mensajes para ahorrar cuota
    let memoriaContext = '';
    if (logs.length % 5 === 0) {
      try {
      const memRes = await fetch('/api/memory');
      const memData = await memRes.json();
      if (memData.memoria && memData.memoria.length > 0) {
        const buenos = memData.memoria.filter(m => m.feedback === 'bueno');
        const malos = memData.memoria.filter(m => m.feedback === 'malo');
        if (buenos.length > 0) {
          memoriaContext += '\n\nRESPUESTAS QUE EL USUARIO APROBÓ (úsalas como referencia):\n';
          buenos.slice(-5).forEach(m => {
            memoriaContext += `- Pregunta: "${m.comando}" → Respuesta aprobada: "${m.respuesta.substring(0, 100)}..."\n`;
          });
        }
        if (malos.length > 0) {
          memoriaContext += '\nRESPUESTAS QUE EL USUARIO RECHAZÓ (evita este estilo):\n';
          malos.slice(-3).forEach(m => {
            memoriaContext += `- Pregunta: "${m.comando}" → Respuesta rechazada: "${m.respuesta.substring(0, 80)}..."\n`;
          });
        }
      }
      } catch(e) { /* memoria no disponible */ }
    } // fin cada 5 mensajes

    const result = await callGemini(text, memoriaContext);

    // Detectar si Kairós quiere enviar un correo
    await detectarYEnviarCorreo(result.respuesta);

    // Detectar y guardar prospecto si Kairós lo indica
    await detectarYGuardarProspecto(result.respuesta);
    hideTyping();

    addMessage('ai', result.respuesta, logIndex);
    
    // Guardar con thought signature para mantener razonamiento del modelo 3.1
    const modelMessage = { 
      role: 'model', 
      parts: [{ text: result.respuesta }] 
    };
    if (result.thoughtSignature) {
      modelMessage.thoughtSignature = result.thoughtSignature;
    }
    messages.push(modelMessage);
    
    saveToHistory('agent', result.respuesta);

    // Update log
    logs[logIndex].response = result.respuesta;
    logs[logIndex].estado = 'ok';
    renderLogs();
    saveLogToSheets(text, result.respuesta, 'pendiente', 'ok');

  } catch(err) {
    hideTyping();
    const errMsg = `Error: ${err.message}`;
    addMessage('ai', errMsg, logIndex);

    logs[logIndex].response = errMsg;
    logs[logIndex].estado = 'error';
    renderLogs();
    saveLogToSheets(text, errMsg, 'pendiente', 'error');
  }

  isLoading = false;
  document.getElementById('sendBtn').disabled = false;
  input.focus();
}

// Gemini API call via servidor
async function callGemini(userMessage, memoriaContext = '') {
  const systemPrompt = (config.systemPrompt || 'Eres Yesi, asistente técnica experta. Responde en español.') + memoriaContext;

  const res = await fetch('/api/chat', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      mensaje: userMessage,
      historial: messages.slice(0, -1),
      systemPrompt
    })
  });

  if (!res.ok) {
    const err = await res.json().catch(() => ({}));
    throw new Error(err.error || `HTTP ${res.status}`);
  }

  const data = await res.json();
  if (!data.success) throw new Error(data.error || 'Error desconocido');
  
  return {
    respuesta: data.respuesta,
    thoughtSignature: data.thoughtSignature
  };
}

// ─── HISTORIAL A LARGO PLAZO ────────────────────────────────────

async function saveToHistory(role, content) {
  try {
    await fetch('/api/history', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ role, content, session: sessionId })
    });
  } catch(e) { /* silencioso */ }
}

async function loadHistory() {
  try {
    const res = await fetch('/api/history');
    const data = await res.json();

    // Inyectar Ancla Vital en el system prompt
    if (data.ancla) {
      config.systemPrompt = data.ancla;
    }

    // Cargar Ventana Móvil (últimos 10 mensajes)
    if (data.historial && data.historial.length > 0) {
      data.historial.forEach(h => {
        if (h.role === 'user') {
          messages.push({ role: 'user', parts: [{ text: h.content }] });
        } else if (h.role === 'agent') {
          messages.push({ role: 'model', parts: [{ text: h.content }] });
        }
      });

      const welcome = document.getElementById('welcomeScreen');
      if (welcome) welcome.remove();
      const container = document.getElementById('chatContainer');
      const div = document.createElement('div');
      div.style.cssText = 'text-align:center;padding:12px;font-size:10px;color:var(--accent3);font-family:"JetBrains Mono",monospace;border:1px solid rgba(16,185,129,0.2);border-radius:6px;background:rgba(16,185,129,0.04);margin-bottom:8px;';
      div.textContent = `🧠 Yesi lista · Ancla cargada · ${data.historial.length} mensajes recientes`;
      container.appendChild(div);
    }

  } catch(e) { /* sin historial, continuar */ }
}

// ─── MEMORIA PERMANENTE ─────────────────────────────────────────
let memoriaPermanente = '';

async function loadMemoria() {
  try {
    const res = await fetch('/api/memoria');
    const data = await res.json();
    if (!data.memoria || data.memoria.length === 0) return;

    // Formatear memoria para inyectar en system prompt
    let texto = '\n\n📌 MEMORIA PERMANENTE (datos importantes que SIEMPRE debes recordar):\n';
    data.memoria.forEach(m => {
      texto += `• [${m.categoria}] ${m.dato}\n`;
    });
    memoriaPermanente = texto;

    // Inyectar en el config
    config.systemPrompt = (config.systemPrompt || '') + memoriaPermanente;

  } catch(e) { /* sin memoria */ }
}

async function guardarEnMemoria(categoria, dato) {
  try {
    await fetch('/api/memoria', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ categoria, dato })
    });
    showToast('💾 Guardado en memoria permanente');
    await loadMemoria(); // Recargar
  } catch(e) {
    showToast('⚠ Error guardando en memoria');
  }
}

function promptRecordar(logIndex) {
  const respuesta = logs[logIndex]?.response || '';
  if (!respuesta) return;

  const categoria = prompt('¿En qué categoría guardar este dato?\n\nEjemplos: Proyecto, Preferencia, Dato importante, Cliente, etc.');
  if (!categoria) return;

  const dato = prompt('¿Qué dato específico quieres que Yesi recuerde siempre?\n\nEjemplo: "Eduardo prefiere respuestas cortas y técnicas"');
  if (!dato) return;

  guardarEnMemoria(categoria, dato);
}

// ─── NOTIFICACIONES TELEGRAM ────────────────────────────────
async function notificarTelegram(mensaje) {
  try {
    await fetch('/api/telegram', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ mensaje })
    });
  } catch(e) { /* silencioso */ }
}

// ─── ENVÍO AUTOMÁTICO DE CORREOS ────────────────────────────
async function detectarYEnviarCorreo(respuesta) {
  try {
    const jsonMatch = respuesta.match(/\{[\s\S]*?"para"\s*:\s*"[^"]+@[^"]+[\s\S]*?\}/);
    if (!jsonMatch) return;
    let datos;
    try { datos = JSON.parse(jsonMatch[0]); } catch(e) { return; }
    if (!datos.para || !datos.cuerpo) return;
    showToast('📧 Enviando correo a ' + datos.para + '...');
    const res = await fetch('/api/correo', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(datos)
    });
    const data = await res.json();
    if (data.success) {
      showToast('✅ Correo enviado a ' + datos.para);
      // Notificar por Telegram
      fetch('/api/telegram', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ mensaje: '📧 <b>Correo enviado</b>\n\nPara: ' + datos.para + '\nAsunto: ' + (datos.asunto || 'Sin asunto') })
      });
    } else {
      showToast('⚠ Error: ' + (data.error || 'No se pudo enviar'));
    }
  } catch(e) { /* No era JSON de correo */ }
}

// ─── GUARDADO AUTOMÁTICO DE PROSPECTOS ──────────────────────
async function detectarYGuardarProspecto(respuesta) {
  try {
    // Limpiar backslashes escapados y comillas tipograficas
    const normalizada = respuesta
      .replace(/\\"/g, '"')
      .replace(/[“”„‟]/g, '"')
      .replace(/[‘’‚‛]/g, "'");

    // Buscar todos los JSON en la respuesta
    const jsonMatches = normalizada.match(/\{[^{}]*"nombre"[^{}]*\}/g);
    if (!jsonMatches) return;

    for (const match of jsonMatches) {
      let datos;
      try { datos = JSON.parse(match); } catch(e) { continue; }
      if (!datos.nombre) continue;

      // Asegurar campos requeridos
      datos.fuente = datos.fuente || 'kairos';
      datos.empresa = datos.empresa || datos.nombre;
      datos.rubro = datos.rubro || '';
      datos.sitio_web = datos.sitio_web || '';
      datos.correo = datos.correo || '';

      showToast('💾 Guardando: ' + datos.nombre + '...');
      const res = await fetch('/api/prospectos', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(datos)
      });
      const data = await res.json();
      if (data.success) {
        showToast('✅ Guardado: ' + datos.nombre);
        // Notificar por Telegram
        fetch('/api/telegram', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ mensaje: '📋 <b>Nuevo prospecto guardado</b>\n\nNombre: ' + datos.nombre + '\nRubro: ' + datos.rubro + '\nFuente: ' + datos.fuente })
        });
      } else {
        showToast('⚠ Error: ' + (data.error || 'No se pudo guardar'));
      }
    }
  } catch(e) { /* No era JSON de prospecto */ }
}

// Init
loadConfig();
loadHistory();
loadMemoria();

// ─── VOZ: Speech to Text (micrófono) ───────────────────────────
let recognition = null;
let isRecording = false;

function toggleMic() {
  if (!('webkitSpeechRecognition' in window) && !('SpeechRecognition' in window)) {
    showToast('⚠ Tu navegador no soporta reconocimiento de voz. Usa Chrome.');
    return;
  }

  if (isRecording) {
    recognition.stop();
    return;
  }

  const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
  recognition = new SpeechRecognition();
  recognition.lang = 'es-PA';
  recognition.continuous = false;
  recognition.interimResults = false;

  recognition.onstart = () => {
    isRecording = true;
    document.getElementById('micBtn').classList.add('recording');
    document.getElementById('chatInput').placeholder = '🎤 Escuchando...';
  };

  recognition.onresult = (event) => {
    const transcript = event.results[0][0].transcript;
    const input = document.getElementById('chatInput');
    input.value = transcript;
    handleInput(input);
  };

  recognition.onend = () => {
    isRecording = false;
    document.getElementById('micBtn').classList.remove('recording');
    document.getElementById('chatInput').placeholder = 'Escribe tu mensaje...';
    // Auto-enviar si hay texto
    const input = document.getElementById('chatInput');
    if (input.value.trim()) sendMessage();
  };

  recognition.onerror = (e) => {
    isRecording = false;
    document.getElementById('micBtn').classList.remove('recording');
    document.getElementById('chatInput').placeholder = 'Escribe tu mensaje...';
    showToast('⚠ Error de micrófono: ' + e.error);
  };

  recognition.start();
}

// ─── VOZ: Text to Speech (altavoz) ─────────────────────────────
let currentUtterance = null;

function speakText(btn, logIndex) {
  if (!('speechSynthesis' in window)) {
    showToast('⚠ Tu navegador no soporta síntesis de voz.');
    return;
  }

  if (window.speechSynthesis.speaking) {
    window.speechSynthesis.cancel();
    document.querySelectorAll('.tts-btn').forEach(b => { b.classList.remove('speaking'); b.textContent = '🔊 Escuchar'; });
    return;
  }

  const text = logs[logIndex] ? logs[logIndex].response : '';
  if (!text || text === '...') return;

  const cleanText = text.replace(/\*\*/g, '').replace(/\*/g, '').replace(/#{1,6} /g, '');
  const utterance = new SpeechSynthesisUtterance(cleanText);
  utterance.lang = 'es-ES';
  utterance.rate = 0.95;
  utterance.pitch = 1;

  utterance.onstart = () => { btn.classList.add('speaking'); btn.textContent = '⏹ Detener'; };
  utterance.onend = () => { btn.classList.remove('speaking'); btn.textContent = '🔊 Escuchar'; };

  function doSpeak() {
    const esVoice = window.speechSynthesis.getVoices().find(v => v.lang.startsWith('es'));
    if (esVoice) utterance.voice = esVoice;
    window.speechSynthesis.cancel();
    setTimeout(() => window.speechSynthesis.speak(utterance), 150);
  }

  window.speechSynthesis.getVoices().length > 0 ? doSpeak() : (window.speechSynthesis.onvoiceschanged = doSpeak);
}
</script>
</body>
</html>